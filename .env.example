# Copy this file to .env and fill in your actual values.
# Never commit a .env file with real secrets to version control.

# Google Gemini API key — required for both text and voice interview modes.
# Text mode uses:  gemini-2.0-flash
# Voice mode uses: gemini-2.0-flash-live-001
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
